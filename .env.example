# NextAuth
AUTH_SECRET=replace-with-a-random-32-byte-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — Guest/Demo login work without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (optional — app runs on in-memory state without this)
DATABASE_URL="file:./dev.db"

# OpenAI (optional — only needed if you wire the command parser to a real LLM)
OPENAI_API_KEY=
